{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "start:tunnel": "expo start --tunnel",
    "start:tunnel:clean": "expo start --tunnel -c",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "cleanup-orphan-auth": "node -r dotenv/config scripts/cleanup-orphan-auth-users.mjs",
    "unsplash-fetch-gallery-images": "node -r dotenv/config scripts/unsplash-fetch-gallery-images.mjs",
    "deploy:delete-account": "supabase functions deploy delete-account --no-verify-jwt",
    "render-verification-email": "npx tsx scripts/render-verification-email.ts",
    "render-password-reset": "npx tsx scripts/render-password-reset.ts",
    "render-account-deleted": "npx tsx scripts/render-account-deleted.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.58.0",
    "expo": "^54.0.10",
    "expo-blur": "~15.0.7",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "zustand": "^5.0.10"
  },
  "overrides": {
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "baseline-browser-mapping": "latest",
    "dotenv": "^17.2.4",
    "supabase": "^2.15.0",
    "typescript": "~5.9.2"
  }
}
