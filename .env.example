# Supabase – get these from Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: redirect URL after email confirmation (e.g. magic link). If unset, app uses dev/local URL.
# EXPO_PUBLIC_EMAIL_CONFIRM_REDIRECT_URL=https://your-app.com/social/auth-callback

# Optional: for scripts that update the DB (e.g. unsplash-fetch-gallery-images)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Unsplash – for pre-fetching gallery meal images (https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here
